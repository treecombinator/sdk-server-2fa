{
  "name": "@treecombinator/sdk-2fa",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "description": "Tree Combinator SDK — 2FA/TOTP domain (RFC 6238).",
  "type": "module",
  "files": ["dist", "AGENTS.md", "README.md", "LICENSE"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "scripts": { "build": "tsup", "prepare": "tsup", "typecheck": "tsc --noEmit", "clean": "rm -rf dist" },
  "dependencies": { "@treecombinator/sdk-core": "github:treecombinator/sdk-core" },
  "devDependencies": { "@cloudflare/workers-types": "^4.20240000.0", "tsup": "^8.5.1", "typescript": "^5.5.0" },
  "repository": { "type": "git", "url": "git+https://github.com/treecombinator/sdk-2fa.git" },
  "publishConfig": { "access": "public" }
}
